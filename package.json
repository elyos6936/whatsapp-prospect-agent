{
  "name": "klanvio",
  "version": "2.1.0",
  "description": "Klanvio — agent WhatsApp IA, prospection et automatisations",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc --noEmit",
    "setup": "npm install",
    "tunnel": "npx cloudflared tunnel --url http://localhost:3000",
    "db:migrate": "node scripts/migrate-sqlite-to-supabase.mjs",
    "deploy:netlify": "node scripts/inject-netlify-config.mjs && npx netlify deploy --prod --dir=public",
    "deploy:hostinger": "bash deploy/hostinger/deploy.sh",
    "mail:test-report": "tsx scripts/send-test-report-email.ts",
    "plan:preview": "tsx scripts/preview-automation-plan.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/jwt": "^10.2.0",
    "@fastify/static": "^8.1.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "google-auth-library": "^10.9.0",
    "openai": "^4.104.0",
    "postgres": "^3.4.7",
    "tsx": "^4.19.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.21",
    "@types/pg": "^8.15.5",
    "typescript": "^5.8.3"
  }
}
