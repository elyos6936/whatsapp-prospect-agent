# PostgreSQL (Supabase) — obligatoire
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Auth JWT (générer une chaîne aléatoire longue)
JWT_SECRET=

# Connexion Google (OAuth) — ID client obtenu sur console.cloud.google.com
# (API & Services → Identifiants → ID client OAuth 2.0, type « Application Web »).
# Le même ID doit être exposé au frontend via VITE_GOOGLE_CLIENT_ID (build Netlify).
GOOGLE_CLIENT_ID=

# Plateforme gérée — IA (DeepSeek par défaut, API compatible OpenAI)
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
# Modèle tool-calling (qualité) : deepseek-v4-pro | deepseek-v4-flash
LLM_MODEL=deepseek-v4-pro
# Rétrocompat : OPENAI_API_KEY est utilisé si DEEPSEEK_API_KEY est vide
OPENAI_API_KEY=
OPENAI_MODEL=

EVOLUTION_API_BASE_URL=https://votre-serveur-evolution.com
EVOLUTION_API_KEY=

PORT=3000

# URL publique du backend (webhooks Evolution)
PUBLIC_URL=https://votre-api.example.com

# CORS (frontend Netlify)
CORS_ORIGINS=https://klanvio.netlify.app,http://localhost:3000
