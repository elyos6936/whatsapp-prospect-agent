# PostgreSQL (Supabase) — obligatoire
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optionnel — peut aussi être saisi dans l'interface
OPENAI_API_KEY=

# Evolution API (WhatsApp) — https://docs.evolutionfoundation.com.br/
EVOLUTION_API_BASE_URL=https://votre-serveur-hostinger.com
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=mon-instance

PORT=3000
OPENAI_MODEL=gpt-4o

# Frontend Netlify → proxy API
KLANVIO_API_URL=

# CORS (backend)
CORS_ORIGINS=https://klanvio.netlify.app,http://localhost:3000
PUBLIC_API_URL=
