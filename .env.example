# PostgreSQL (Supabase) — obligatoire
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Auth JWT (générer une chaîne aléatoire longue)
JWT_SECRET=

# Plateforme gérée — clés opérateur (une fois, pas par utilisateur)
OPENAI_API_KEY=
EVOLUTION_API_BASE_URL=https://votre-serveur-evolution.com
EVOLUTION_API_KEY=

PORT=3000
OPENAI_MODEL=gpt-4o

# URL publique du backend (webhooks Evolution)
PUBLIC_URL=https://votre-api.example.com

# CORS (frontend Netlify)
CORS_ORIGINS=https://klanvio.netlify.app,http://localhost:3000
