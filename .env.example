# PostgreSQL (Supabase) — obligatoire
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Auth JWT (générer une chaîne aléatoire longue)
JWT_SECRET=

# Connexion Google (OAuth) — ID client obtenu sur console.cloud.google.com
# (API & Services → Identifiants → ID client OAuth 2.0, type « Application Web »).
# Le même ID doit être exposé au frontend via VITE_GOOGLE_CLIENT_ID (build Netlify).
# ⚠️ Client LOGIN uniquement (GIS / ID token) — distinct du client Intégrations ci-dessous.
GOOGLE_CLIENT_ID=

# Google Intégrations (Sheets / futur Forms, Calendar) — 2ᵉ OAuth Client Web, séparé du login.
# Redirect URI exacte :
#   {PUBLIC_URL}/api/integrations/google/callback
# ex. https://klanvio-api.srv1820011.hstgr.cloud/api/integrations/google/callback
GOOGLE_INTEGRATIONS_CLIENT_ID=
GOOGLE_INTEGRATIONS_CLIENT_SECRET=
# Optionnel si différent du défaut ci-dessus :
# GOOGLE_INTEGRATIONS_REDIRECT_URI=

# Front(s) pour redirects OAuth — liste CSV OK (comme CORS_ORIGINS).
# La redirect utilise www.klanvio.com si présent, sinon la 1ʳᵉ URL https.
APP_URL=https://www.klanvio.com,https://klanvio.com,https://klanvio.netlify.app

# Typeform OAuth (Applications → Create application sur admin.typeform.com)
# Redirect URI à enregistrer chez Typeform (exact) :
#   {PUBLIC_URL}/api/integrations/typeform/callback
# ex. https://klanvio-api.srv1820011.hstgr.cloud/api/integrations/typeform/callback
TYPEFORM_CLIENT_ID=
TYPEFORM_CLIENT_SECRET=
# Optionnel si différent du défaut ci-dessus :
# TYPEFORM_REDIRECT_URI=

# Chiffrement au repos des tokens d'intégrations (AES-256-GCM).
# Générer UNE FOIS : openssl rand -hex 32  (ou node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
# ⚠️ Ne JAMAIS changer cette clé en production : tous les tokens stockés deviennent illisibles.
TOKENS_ENCRYPTION_KEY=

# Plateforme gérée — IA (DeepSeek par défaut, API compatible OpenAI)
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
# Modèle : deepseek-v4-pro UNIQUEMENT (Thinking ON). Ne pas utiliser deepseek-v4-flash.
LLM_MODEL=deepseek-v4-pro
# Rétrocompat : OPENAI_API_KEY est utilisé si DEEPSEEK_API_KEY est vide
OPENAI_API_KEY=
OPENAI_MODEL=

EVOLUTION_API_BASE_URL=https://votre-serveur-evolution.com
EVOLUTION_API_KEY=

PORT=3000

# URL publique du backend (webhooks Evolution)
PUBLIC_URL=https://votre-api.example.com

# CORS (frontend Netlify)
CORS_ORIGINS=https://www.klanvio.com,https://klanvio.com,http://localhost:3000,http://localhost:5174

# Resend — rapports quotidiens par e-mail (from: rapports@klanvio.com)
# Domaine klanvio.com doit être vérifié dans le dashboard Resend (DNS Hostinger).
RESEND_API_KEY=
RESEND_FROM=rapports@klanvio.com
