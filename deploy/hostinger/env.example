# Klanvio API — production Hostinger
PORT=3001
NODE_ENV=production

# Supabase Postgres (Settings → Database → Connection string, mode Transaction pooler)
DATABASE_URL=postgresql://postgres.omquaouhfifynvrpqilv:[MOT_DE_PASSE]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

SUPABASE_URL=https://omquaouhfifynvrpqilv.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# IA — DeepSeek (remplace OpenAI)
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
LLM_MODEL=deepseek-v4-pro
OPENAI_API_KEY=
OPENAI_MODEL=

# Auth JWT
JWT_SECRET=

# Evolution API (plateforme — une instance par utilisateur klanvio_<id>)
EVOLUTION_API_BASE_URL=https://evolution-api-kxse.srv1820011.hstgr.cloud
EVOLUTION_API_KEY=

# Origines autorisées (frontend Netlify)
CORS_ORIGINS=https://www.klanvio.com,https://klanvio.com

# URL publique de cette API (webhooks Evolution + callback OAuth Typeform)
PUBLIC_URL=https://klanvio-api.srv1820011.hstgr.cloud

# Front(s) redirects OAuth — liste CSV OK ; redirect = www.klanvio.com si présent
APP_URL=https://www.klanvio.com,https://klanvio.com,https://klanvio.netlify.app

# Typeform OAuth — Redirect URI exacte à coller dans l'app Typeform :
# https://klanvio-api.srv1820011.hstgr.cloud/api/integrations/typeform/callback
TYPEFORM_CLIENT_ID=
TYPEFORM_CLIENT_SECRET=

# Google Intégrations (OAuth client séparé du login GOOGLE_CLIENT_ID)
# Redirect URI :
# https://klanvio-api.srv1820011.hstgr.cloud/api/integrations/google/callback
GOOGLE_INTEGRATIONS_CLIENT_ID=
GOOGLE_INTEGRATIONS_CLIENT_SECRET=

# Chiffrement tokens intégrations (64 hex). Ne JAMAIS changer en prod.
# openssl rand -hex 32
TOKENS_ENCRYPTION_KEY=

# Resend — rapports quotidiens (domaine klanvio.com vérifié côté Resend)
RESEND_API_KEY=
RESEND_FROM=rapports@klanvio.com
